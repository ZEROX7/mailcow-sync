AUTHENTIK_URL=https://auth.example.com/api/v3/core/users/
AUTHENTIK_TOKEN=replace-with-authentik-service-account-token

MAILCOW_URL=https://mail.example.com
MAILCOW_API_KEY=replace-with-mailcow-api-key

POLL_INTERVAL_SECONDS=300
HTTP_TIMEOUT_SECONDS=20
LOG_LEVEL=INFO

DRY_RUN=false
RUN_ONCE=false

SKIP_INACTIVE_USERS=true
DELETE_STALE_ALIASES=true
DELETE_STALE_MAILBOXES=false

MAILBOX_QUOTA_MB=2048
MAILBOX_PASSWORD_LENGTH=32

MANAGED_DOMAINS=example1.com,example2.com
PRIMARY_MAILBOX_ALLOWED_DOMAINS=example1.com

MANAGED_ALIAS_COMMENT=managed-by-authentik-sync
